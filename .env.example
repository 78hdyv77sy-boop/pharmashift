# ----------------------------------------------------------------------------
# PHARMASHIFT — Umgebungsvariablen (kopieren nach .env und ausfüllen)
# ----------------------------------------------------------------------------

# MySQL-Verbindung
DATABASE_URL="mysql://user:password@localhost:3306/pharmashift"

# Auth.js / NextAuth — geheimer Schlüssel (z.B. `openssl rand -base64 32`)
AUTH_SECRET="change-me"
# Basis-URL der App
AUTH_URL="http://localhost:3000"

# Google OAuth (Google Cloud Console -> OAuth-Client)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend (Transaktionsmails)
RESEND_API_KEY=""
EMAIL_FROM="PharmaShift <no-reply@deine-domain.de>"

# OpenAI (Voice / Whisper / Realtime)
OPENAI_API_KEY=""

# Anthropic (Voice-Agent / Tool-Use)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-7"

# Seed-Superadmin (erster Plattform-Admin)
SEED_ADMIN_EMAIL="admin@pharmashift.local"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# Feature-Flags (UX-P1 / Architektur-Review O1)
# CMS-Bereich (Seiten/Menüs/Medien) einblenden: "1" = an, sonst aus
NEXT_PUBLIC_FEATURE_CMS=0

# ---- Deployment-Upgrades (optional, erst auf dem Hosting nötig) ----
# Job-/Cron-System Inngest: lokal via `npx inngest-cli dev` nutzbar; in Produktion
# aus dem Inngest-Dashboard beziehen. Ohne diese Werte bleibt /api/inngest inaktiv.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Fehler-Überwachung Sentry (siehe README, Abschnitt "Deployment-Upgrades")
# SENTRY_DSN=""

# Verteiltes Rate-Limit via Upstash Redis (siehe README)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""
